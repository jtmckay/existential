commands:
  ai_router: opencode run {prompt}
  ai_interactive: opencode
max_retries: 3
max_depth: 10
max_log_size: 2097152
default_routine: develop
hooks:
  beforeAll: /work/.decree/hooks/config-watch.sh
  afterAll: /work/.decree/hooks/config-watch.sh
  beforeEach: ""
  afterEach: ""
routines:
  actual-budget:
    enabled: false
  actual-budget-parse:
    enabled: false
  clean-runs:
    enabled: true
  develop:
    enabled: false
  gmail:
    enabled: false
  gmail-sync:
    enabled: false
  notes:
    enabled: false
  notify:
    enabled: true
