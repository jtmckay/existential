commands:
  ai_router: opencode run {prompt}
  ai_interactive: opencode
max_retries: 3
max_depth: 100
max_log_size: 2097152
default_routine: develop
hooks:
  beforeAll: ""
  afterAll: ""
  beforeEach: /work/.decree/hooks/config-watch.sh
  afterEach: /work/.decree/hooks/config-watch.sh
routines:
  actual-budget:
    enabled: false
  actual-budget-parse:
    enabled: false
  clean-runs:
    enabled: true
  develop:
    enabled: false
  file-processor:
    enabled: false
  minio-router:
    enabled: false
  gmail:
    enabled: false
  gmail-sync:
    enabled: false
  notes:
    enabled: false
  notify:
    enabled: true
