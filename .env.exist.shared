# Existential Stack Configuration
# Run existential.sh script, or copy this file to global.env and fill in your values

#==================================================#
#               Global Configuration               #
#==================================================#

# Service Enablement Configuration
# Set to 'true' to enable a service, 'false' to disable
# Each service corresponds to a subdirectory with docker-compose.yml

# AI Services
EXIST_IS_AI_CHATTERBOX=false
EXIST_IS_AI_COMFYUI=false
EXIST_IS_AI_FIRECRAWL=false
EXIST_IS_AI_HERMES=false
EXIST_IS_AI_HONCHO=false
EXIST_IS_AI_MCP=false
EXIST_IS_AI_OLLAMA=false
EXIST_IS_AI_OPEN_WEBUI=false
EXIST_IS_AI_OPENVIKING=false
EXIST_IS_AI_WHISPERX=false

# Automation Services
EXIST_IS_AUTOMATIONS_PLAYWRIGHT=false

# Hosting Services
EXIST_IS_HOSTING_AUTHELIA=false
EXIST_IS_HOSTING_CADDY=true
EXIST_IS_HOSTING_GRAFANA=false
EXIST_IS_HOSTING_LOKI=false
EXIST_IS_HOSTING_PIHOLE=false
EXIST_IS_HOSTING_PORTAINER=false
EXIST_IS_HOSTING_PROMETHEUS=false
EXIST_IS_HOSTING_UPTIME_KUMA=false

# NAS Services
EXIST_IS_NAS_COLLABORA=false
EXIST_IS_NAS_MINIO=false
EXIST_IS_NAS_NEXTCLOUD=false
EXIST_IS_NAS_REDIS=false

# Application Services
EXIST_IS_SERVICES_ACTUAL_BUDGET=false
EXIST_IS_SERVICES_APPSMITH=false
EXIST_IS_SERVICES_CODE_SERVER=false
EXIST_IS_SERVICES_DASHY=false
EXIST_IS_SERVICES_DECREE=false
EXIST_IS_SERVICES_IMMICH=false # Recommended to run this directly from the immich directory (not here)
EXIST_IS_SERVICES_IT_TOOLS=false
EXIST_IS_SERVICES_LOWCODER=false
EXIST_IS_SERVICES_MEALIE=false
EXIST_IS_SERVICES_NOCODB=false
EXIST_IS_SERVICES_NTFY=false
EXIST_IS_SERVICES_HOMEASSISTANT=false
EXIST_IS_SERVICES_VIKUNJA=false

# Set to true if the 'exist' Docker network is created externally (e.g. via docker network create)
# Set to false to have it created and managed by Docker Compose
EXIST_NETWORK_EXTERNAL=false

# Default email to use in services
EXIST_EMAIL=EXIST_CLI

# Default username to use in services
EXIST_USERNAME=EXIST_CLI
# Default password to use in services
EXIST_PASSWORD=EXIST_24_CHAR_PASSWORD

# Host user/group IDs. Every container runs as this uid:gid (referenced in service
# compose files as ${EXIST_PUID:-1000}:${EXIST_PGID:-1000}), so files written into
# bind-mounted volumes stay owned by — and deletable by — the user running the stack.
# existential.sh auto-detects and writes these (from `id -u`/`id -g`) on first run if
# absent, defaulting to 1000. Override here only if your containers must run as a
# different user than the one invoking docker compose.
# EXIST_PUID=1000
# EXIST_PGID=1000

# Base domain for every `<slug>.<domain>` hostname. piHole resolves the whole
# domain (and all subdomains) to EXIST_LOCAL_HOST_IP via a single wildcard record,
# and Caddy fronts each `<slug>.<domain>`. The default keeps everything under a
# single-label namespace beneath .internal so a SECOND stack on the same LAN can
# pick a different one (e.g. y.internal) without colliding. Advanced: set a real
# domain you own and drop a valid cert into hosting/caddy/certs/ — caddy's
# exist.initial.sh skips minting whenever a leaf cert already exists.
EXIST_DOMAIN=x.internal

# LAN IP of the machine running caddy. piHole's single wildcard record points the
# whole EXIST_DOMAIN here so other devices on the LAN resolve `<slug>.<domain>` →
# Caddy → the right container.
EXIST_LOCAL_HOST_IP=EXIST_CLI

# LAN IP of the machine running the services, when caddy + piHole live on a
# separate front-door host (peer mode). The front-door Caddy forwards every
# `<slug>.<domain>` to this IP, where a second Caddy routes to the right container.
# Optional — blank defaults to LOCAL_HOST_IP (single-host / co-located).
# DEFAULT_FROM: EXIST_LOCAL_HOST_IP
EXIST_PEER_HOST_IP=

# Public domain for legit (Let's Encrypt) certs alongside the .internal
# hostnames. Blank = local-only, no public-domain blocks generated. When set
# (e.g. homelab.example.com), Caddy will additionally serve every service at
# <slug>.<EXIST_PUBLIC_DOMAIN> with real ACME certs. Requires:
#   - You own the domain
#   - <domain> and *.<domain> resolve to your public IP
#   - Ports 80 + 443 forwarded from your router to this machine
#     (80 is required for the ACME HTTP-01 challenge)
# Run ./existential.sh setup caddy to (re)generate Caddyfile.public after
# changing this value.
EXIST_PUBLIC_DOMAIN=

# Hermes gateway API key — shared by hermes-agent, and open-webui
EXIST_HERMES_API_KEY=EXIST_32_CHAR_HEX_KEY

# LightRAG API key — shared by lightrag container and hermes-agent MCP config
EXIST_LIGHTRAG_API_KEY=EXIST_32_CHAR_HEX_KEY

# NTFY (shared across services)
# Container-to-container URL (Docker DNS). Token is generated by
# ./existential.sh run ntfy setup after first boot.
EXIST_NTFY_URL=http://ntfy:80
EXIST_NTFY_TOKEN=

# Telegram fallback — used by notify.sh when ntfy is unreachable
# Create a bot: https://t.me/BotFather → /newbot
# Get chat ID: message the bot, then https://api.telegram.org/bot<TOKEN>/getUpdates
EXIST_TELEGRAM_BOT_TOKEN=
EXIST_TELEGRAM_CHAT_ID=

# Docker network subnet (must match your docker network create command)
EXIST_DOCKER_NETWORK_SUBNET=10.0.0.0/24

#==================================================#
#                 NAS Configuration                #
#==================================================#

# Persistent data is stored as host bind mounts — never Docker-managed volumes.
# Without an NFS host mount below, every volume lives under <repo>/volumes/<name>.
# To put persistent data on a NAS, mount the NFS export on the HOST (fstab/autofs),
# then set EXIST_NFS_HOST_MOUNT to that mountpoint. SERVER_ADDRESS/BASE_PATH below
# only document where the export lives (used by the NAS Storage quest); Docker no
# longer mounts NFS itself. See: ./existential.sh run (NAS Storage quest).

# Host mountpoint of the NFS export (where the NAS is mounted on THIS machine).
# EG /mnt/nas — leave blank to keep all data under <repo>/volumes/.
EXIST_NFS_HOST_MOUNT=EXIST_CLI
# NFS Server IP Address (documentation / quest only)
# EG 192.168.1.8
# (skip if you don't want to use an existing NAS)
EXIST_NFS_SERVER_ADDRESS=EXIST_CLI
# NFS Server Share Base Path (documentation / quest only)
# EG /mnt/container_data
# NFS (skip if you don't want to use an existing NAS)
EXIST_NFS_BASE_PATH=EXIST_CLI

# Backup destination — any rclone remote ("<remote>:<path>"). Set via
# ./existential.sh setup backup after configuring rclone. Leave blank to
# disable scheduled DB backups; volume backups are invoked manually or via
# host cron (./existential.sh backup volumes [tier]).
EXIST_BACKUP_RCLONE_REMOTE=

# EG: minio-api.x.internal
EXIST_MINIO_DOMAIN=
# EG: https://minio-api.x.internal
EXIST_MINIO_SERVER_URL=

# Bearer token minIO uses when posting to the decree /minio webhook endpoint
EXIST_DECREE_MINIO_WEBHOOK_AUTH_TOKEN=EXIST_32_CHAR_HEX_KEY

# EG: https://nextcloud.x.internal
EXIST_NEXTCLOUD_DOMAIN=

EXIST_REDIS_PASSWORD=EXIST_24_CHAR_PASSWORD

# OIDC client secrets — one source of truth. The same value is rendered into
# Authelia's configuration (as $plaintext$<value>) and each app's environment.
EXIST_OIDC_GRAFANA_CLIENT_SECRET=EXIST_64_CHAR_HEX_KEY
EXIST_OIDC_MEALIE_CLIENT_SECRET=EXIST_64_CHAR_HEX_KEY
EXIST_OIDC_VIKUNJA_CLIENT_SECRET=EXIST_64_CHAR_HEX_KEY
EXIST_OIDC_OPEN_WEBUI_CLIENT_SECRET=EXIST_64_CHAR_HEX_KEY
