# Authelia secrets — generated at render time, aggregated into the root .env.
# Names match Authelia's native AUTHELIA_* env overrides (mapped 1:1 in compose).
AUTHELIA_SESSION_SECRET=EXIST_64_CHAR_HEX_KEY
AUTHELIA_STORAGE_ENCRYPTION_KEY=EXIST_64_CHAR_HEX_KEY
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=EXIST_64_CHAR_HEX_KEY
