PIHOLE_PASSWORD=EXIST_PASSWORD

# LAN IPs for the LOCAL_HOST_IP / PEER_HOST_IP records live in .env.exist
# (EXIST_LOCAL_HOST_IP / EXIST_PEER_HOST_IP). They flow into the master .env
# at compose-generation time and are available to docker-compose substitution.
#
# After bringing piHole up, point your LAN router's primary DNS at this machine
# so `<slug>.internal` resolves correctly across the network.
