PI_PASSWORD=EXIST_DEFAULT_PASSWORD

# LAN IPs for the LOCAL_HOST_IP / PEER_HOST_IP records configured in
# docker-compose.yml. Both source from .env.exist so the same pair flows to
# every service that needs them.
#
# After bringing piHole up, point your LAN router's primary DNS at this machine
# so `<slug>.lan` resolves correctly across the network.
EXIST_DEFAULT_LOCAL_HOST_IP=EXIST_DEFAULT_LOCAL_HOST_IP
EXIST_DEFAULT_PEER_HOST_IP=EXIST_DEFAULT_PEER_HOST_IP
