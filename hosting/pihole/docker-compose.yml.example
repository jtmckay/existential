# More info at https://github.com/pi-hole/docker-pi-hole/ and https://docs.pi-hole.net/
#
# You will need to uncomment and disable the stub DNS
# /etc/systemd/resolved.conf
# DNSStubListener=no
#
# ── DNS convention ────────────────────────────────────────────────────────────
# Every container that publishes a web UI or HTTP endpoint gets a `<slug>.internal`
# A-record. The slug is the lowercase-hyphenated form of the service folder /
# container name. piHole points the slug at one of two hosts:
#
#   EXIST_LOCAL_HOST_IP — this machine (active line)
#   EXIST_PEER_HOST_IP  — another machine on the LAN (commented line)
#
# To migrate a service between machines, comment the active line and uncomment
# the other one. Both lines are intentionally kept side-by-side so the option
# is visible at a glance.
#
# Each slug must have a matching reverse_proxy block in hosting/caddy/Caddyfile.
# The trailing comment on each record points at that backend so the coupling
# stays visible.

services:
  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    networks:
      - exist
    ports:
      # DNS Ports
      - "53:53/tcp"
      - "53:53/udp"
      # Default HTTP Port
      - "42480:80/tcp"
      # Default HTTPs Port. FTL will generate a self-signed certificate
      - "42443:443/tcp"
      # Uncomment the line below if you are using Pi-hole as your DHCP server
      #- "67:67/udp"
      # Uncomment the line below if you are using Pi-hole as your NTP server
      #- "123:123/udp"
    environment:
      # Set the appropriate timezone for your location (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones), e.g:
      TZ: 'America/Denver'
      # Set a password to access the web interface. Not setting one will result in a random password being assigned
      FTLCONF_webserver_api_password: ${PIHOLE_PASSWORD}
      # If using Docker's default `bridge` network setting the dns listening mode should be set to 'ALL'
      FTLCONF_dns_listeningMode: 'ALL'
      # A records — see "DNS convention" header for the LOCAL/PEER pattern.
      FTLCONF_dns_hosts: |
        # ── ai ────────────────────────────────────────────────────────────────
        # chatterbox      →  Caddy: chatterbox:8000          (ai/chatterbox)
        ${EXIST_LOCAL_HOST_IP} chatterbox.internal
        # ${EXIST_PEER_HOST_IP} chatterbox.internal

        # hermes-agent    →  Caddy: hermes-agent:8642        (ai/hermes — OpenAI-compatible API)
        ${EXIST_LOCAL_HOST_IP} hermes-agent.internal
        # ${EXIST_PEER_HOST_IP} hermes-agent.internal

        # hermes-dashboard →  Caddy: hermes-agent:9119       (ai/hermes — web dashboard)
        ${EXIST_LOCAL_HOST_IP} hermes-dashboard.internal
        # ${EXIST_PEER_HOST_IP} hermes-dashboard.internal

        # hermes-workspace →  Caddy: hermes-workspace:3000   (ai/hermes — workspace UI)
        ${EXIST_LOCAL_HOST_IP} hermes-workspace.internal
        # ${EXIST_PEER_HOST_IP} hermes-workspace.internal

        # librechat        →  Caddy: librechat-client:80     (ai/librechat)
        ${EXIST_LOCAL_HOST_IP} librechat.internal
        # ${EXIST_PEER_HOST_IP} librechat.internal

        # lightrag         →  Caddy: lightrag:9621           (ai/lightrag — REST + MCP)
        ${EXIST_LOCAL_HOST_IP} lightrag.internal
        # ${EXIST_PEER_HOST_IP} lightrag.internal

        # ollama           →  Caddy: ollama:11434            (ai/ollama)
        ${EXIST_LOCAL_HOST_IP} ollama.internal
        # ${EXIST_PEER_HOST_IP} ollama.internal

        # open-webui       →  Caddy: open-webui:8080         (ai/open-webui)
        ${EXIST_LOCAL_HOST_IP} open-webui.internal
        # ${EXIST_PEER_HOST_IP} open-webui.internal

        # mcp-playwright   →  Caddy: mcp-playwright:8931     (ai/mcp)
        ${EXIST_LOCAL_HOST_IP} mcp-playwright.internal
        # ${EXIST_PEER_HOST_IP} mcp-playwright.internal

        # whisper          →  Caddy: whisper:8000            (ai/whisper)
        ${EXIST_LOCAL_HOST_IP} whisper.internal
        # ${EXIST_PEER_HOST_IP} whisper.internal

        # ── services ──────────────────────────────────────────────────────────
        # actual-budget    →  Caddy: actual-budget:5006      (services/actual-budget)
        ${EXIST_LOCAL_HOST_IP} actual-budget.internal
        # ${EXIST_PEER_HOST_IP} actual-budget.internal

        # appsmith         →  Caddy: appsmith:80             (services/appsmith)
        ${EXIST_LOCAL_HOST_IP} appsmith.internal
        # ${EXIST_PEER_HOST_IP} appsmith.internal

        # dashy            →  Caddy: dashy:8080              (services/dashy — main dashboard)
        ${EXIST_LOCAL_HOST_IP} dashy.internal
        # ${EXIST_PEER_HOST_IP} dashy.internal

        # decree-webhook   →  Caddy: decree-webhook:${DECREE_WEBHOOK_PORT}  (services/decree — inbound webhooks)
        ${EXIST_LOCAL_HOST_IP} decree-webhook.internal
        # ${EXIST_PEER_HOST_IP} decree-webhook.internal

        # immich           →  Caddy: immich-server:2283      (services/immich)
        ${EXIST_LOCAL_HOST_IP} immich.internal
        # ${EXIST_PEER_HOST_IP} immich.internal

        # it-tools         →  Caddy: it-tools:80             (services/it-tools)
        ${EXIST_LOCAL_HOST_IP} it-tools.internal
        # ${EXIST_PEER_HOST_IP} it-tools.internal

        # lowcoder         →  Caddy: lowcoder-frontend:3000  (services/lowcoder)
        ${EXIST_LOCAL_HOST_IP} lowcoder.internal
        # ${EXIST_PEER_HOST_IP} lowcoder.internal

        # mealie           →  Caddy: mealie:9000             (services/mealie)
        ${EXIST_LOCAL_HOST_IP} mealie.internal
        # ${EXIST_PEER_HOST_IP} mealie.internal

        # ntfy             →  Caddy: ntfy:80                 (services/ntfy)
        ${EXIST_LOCAL_HOST_IP} ntfy.internal
        # ${EXIST_PEER_HOST_IP} ntfy.internal

        # nocodb           →  Caddy: nocodb:8080             (services/nocodb)
        ${EXIST_LOCAL_HOST_IP} nocodb.internal
        # ${EXIST_PEER_HOST_IP} nocodb.internal

        # vikunja          →  Caddy: vikunja:3456            (services/vikunja)
        ${EXIST_LOCAL_HOST_IP} vikunja.internal
        # ${EXIST_PEER_HOST_IP} vikunja.internal

        # ── hosting ───────────────────────────────────────────────────────────
        # grafana          →  Caddy: grafana:3000            (hosting/grafana)
        ${EXIST_LOCAL_HOST_IP} grafana.internal
        # ${EXIST_PEER_HOST_IP} grafana.internal

        # pihole           →  Caddy: pihole:80               (hosting/pihole — admin UI)
        ${EXIST_LOCAL_HOST_IP} pihole.internal
        # ${EXIST_PEER_HOST_IP} pihole.internal

        # portainer        →  Caddy: portainer:9443 (https)  (hosting/portainer)
        ${EXIST_LOCAL_HOST_IP} portainer.internal
        # ${EXIST_PEER_HOST_IP} portainer.internal

        # prometheus       →  Caddy: prometheus:9090         (hosting/prometheus)
        ${EXIST_LOCAL_HOST_IP} prometheus.internal
        # ${EXIST_PEER_HOST_IP} prometheus.internal

        # uptime-kuma      →  Caddy: uptime-kuma:3001        (hosting/uptime-kuma)
        ${EXIST_LOCAL_HOST_IP} uptime-kuma.internal
        # ${EXIST_PEER_HOST_IP} uptime-kuma.internal

        # ── nas ───────────────────────────────────────────────────────────────
        # collabora        →  Caddy: collabora:9980          (nas/collabora)
        ${EXIST_LOCAL_HOST_IP} collabora.internal
        # ${EXIST_PEER_HOST_IP} collabora.internal

        # minio            →  Caddy: minio:9001              (nas/minio — console)
        ${EXIST_LOCAL_HOST_IP} minio.internal
        # ${EXIST_PEER_HOST_IP} minio.internal

        # minio-api        →  Caddy: minio:9000              (nas/minio — S3 API)
        ${EXIST_LOCAL_HOST_IP} minio-api.internal
        # ${EXIST_PEER_HOST_IP} minio-api.internal

        # nextcloud        →  Caddy: nextcloud:80            (nas/nextcloud)
        ${EXIST_LOCAL_HOST_IP} nextcloud.internal
        # ${EXIST_PEER_HOST_IP} nextcloud.internal
    volumes:
      # For persisting Pi-hole's databases and common configuration file
      - './etc-pihole:/etc/pihole'
      # Uncomment the below if you have custom dnsmasq config files that you want to persist. Not needed for most starting fresh with Pi-hole v6. If you're upgrading from v5 you and have used this directory before, you should keep it enabled for the first v6 container start to allow for a complete migration. It can be removed afterwards. Needs environment variable FTLCONF_misc_etc_dnsmasq_d: 'true'
      #- './etc-dnsmasq.d:/etc/dnsmasq.d'
    cap_add:
      # See https://docs.pi-hole.net/docker/#note-on-capabilities
      # Required if you are using Pi-hole as your DHCP server, else not needed
      - NET_ADMIN
      # Required if you are using Pi-hole as your NTP client to be able to set the host's system time
      - SYS_TIME
      # Optional, if Pi-hole should get some more processing time
      - SYS_NICE

networks:
  exist:
    external: true
