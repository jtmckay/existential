# Domain Caddy serves every <slug> under. The Caddyfile reads it as Caddy's native
# env form {$CADDY_DOMAIN}, so the live Caddyfile never bakes the domain — change it
# here (or override the container env) and restart caddy, no re-render needed.
# Defaults to the stack-wide EXIST_DOMAIN.
CADDY_DOMAIN=EXIST_DOMAIN
