# Caddy reverse proxy — `.internal` convention.
#
# Each block fronts one logical endpoint on the LAN. The hostname matches the
# slug used in hosting/piHole/docker-compose.yml's FTLCONF_dns_hosts list —
# keep the two in sync when adding or removing services.
#
# ── Trusting Caddy's internal CA ──────────────────────────────────────────
# `tls internal` makes Caddy issue certs from its own local CA. Browsers
# warn until each device has imported the root cert. After Caddy has come up
# at least once, dump the root and install it on every machine that needs to
# access the homelab without warnings:
#
#   docker exec caddy cat /data/caddy/pki/authorities/local/root.crt \
#       > existential-ca.crt
#
# Then on each device:
#   - Linux: sudo cp existential-ca.crt /usr/local/share/ca-certificates/ \
#            && sudo update-ca-certificates
#   - macOS: drag into Keychain, mark "Always Trust"
#   - iOS / Android: install via MDM or AirDrop / Settings → Security
#   - Firefox: import via about:preferences#privacy → View Certificates
#
# The root cert lives in the `caddy_data` volume, so it survives container
# rebuilds. Only regenerate / re-distribute if that volume is wiped.

{
  auto_https disable_redirects
}

(error_handling) {
  handle_errors {
    root * /var/www/html
    file_server
    rewrite * /error.html
  }
}

# ── ai ──────────────────────────────────────────────────────────────────────
chatterbox.internal {
  tls internal
  import error_handling
  reverse_proxy chatterbox:8000
}

comfyui.internal {
  tls internal
  import error_handling
  reverse_proxy comfyui:8188
}

hermes-agent.internal {
  tls internal
  import error_handling
  reverse_proxy hermes-agent:8642
}

hermes-dashboard.internal {
  tls internal
  import error_handling
  reverse_proxy hermes-agent:9119
}

hermes-workspace.internal {
  tls internal
  import error_handling
  reverse_proxy hermes-workspace:3000
}

lightrag.internal {
  tls internal
  import error_handling
  reverse_proxy lightrag:9621
}

ollama.internal {
  tls internal
  import error_handling
  reverse_proxy ollama:11434
}

open-webui.internal {
  tls internal
  import error_handling
  reverse_proxy open-webui:8080
}

mcp-playwright.internal {
  tls internal
  import error_handling
  reverse_proxy mcp-playwright:8931
}

whisperx.internal {
  tls internal
  import error_handling
  reverse_proxy whisperx:8000
}

# ── services ────────────────────────────────────────────────────────────────
actual-budget.internal {
  tls internal
  import error_handling
  reverse_proxy actual-budget:5006
}

appsmith.internal {
  tls internal
  import error_handling
  reverse_proxy appsmith:80
}

dashy.internal {
  tls internal
  import error_handling
  reverse_proxy dashy:8080
}

decree-webhook.internal {
  tls internal
  import error_handling
  reverse_proxy decree-webhook:{$DECREE_WEBHOOK_PORT}
}

homeassistant.internal {
  tls internal
  import error_handling
  reverse_proxy homeassistant:8123
}

immich.internal {
  tls internal
  import error_handling
  reverse_proxy immich-server:2283
}

it-tools.internal {
  tls internal
  import error_handling
  reverse_proxy it-tools:80
}

lowcoder.internal {
  tls internal
  import error_handling
  reverse_proxy lowcoder-frontend:3000
}

mealie.internal {
  tls internal
  import error_handling
  reverse_proxy mealie:9000
}

ntfy.internal {
  tls internal
  import error_handling
  reverse_proxy ntfy:80
}

nocodb.internal {
  tls internal
  import error_handling
  reverse_proxy nocodb:8080
}

vikunja.internal {
  tls internal
  import error_handling
  reverse_proxy vikunja:3456
}

# ── hosting ─────────────────────────────────────────────────────────────────
grafana.internal {
  tls internal
  import error_handling
  reverse_proxy grafana:3000
}

pihole.internal {
  tls internal
  import error_handling
  reverse_proxy pihole:80
}

# Portainer serves HTTPS on 9443 with its own self-signed cert. Caddy talks to
# it over TLS and skips verification — the user-facing cert is still Caddy's.
portainer.internal {
  tls internal
  import error_handling
  reverse_proxy https://portainer:9443 {
    transport http {
      tls
      tls_insecure_skip_verify
    }
  }
}

prometheus.internal {
  tls internal
  import error_handling
  reverse_proxy prometheus:9090
}

uptime-kuma.internal {
  tls internal
  import error_handling
  reverse_proxy uptime-kuma:3001
}

# ── nas ─────────────────────────────────────────────────────────────────────
collabora.internal {
  tls internal
  import error_handling
  reverse_proxy collabora:9980
}

# minio web console (port 9001)
minio.internal {
  tls internal
  import error_handling
  reverse_proxy minio:9001
}

# minio S3 API (port 9000)
minio-api.internal {
  tls internal
  import error_handling
  reverse_proxy minio:9000
}

nextcloud.internal {
  tls internal
  import error_handling
  redir /.well-known/carddav /remote.php/dav/ 301
  redir /.well-known/caldav /remote.php/dav/ 301
  reverse_proxy nextcloud:80
}
