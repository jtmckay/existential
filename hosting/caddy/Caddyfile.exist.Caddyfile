# Caddy reverse proxy — `.internal` convention.
#
# Each block fronts one logical endpoint on the LAN. The hostname matches the
# slug used in hosting/piHole/docker-compose.yml's FTLCONF_dns_hosts list —
# keep the two in sync when adding or removing services.
#
# ── Stable local TLS ( `import internal_tls` ) ─────────────────────────────
# We deliberately do NOT use `tls internal`: Caddy auto-rotates its internal
# leaf certs (~12h) and keeps the CA in the caddy_data volume, so a volume wipe
# — or a device that trusted a rotating leaf instead of the CA — silently breaks
# trust and forces a re-setup (the ntfy mobile app is the usual casualty).
#
# Instead, caddy's exist.initial.sh mints ONE long-lived pair on the host into
# hosting/caddy/certs/ (mounted at /etc/caddy/certs/):
#   - internal-ca.pem        your private CA, valid 10 years   ← install on devices
#   - internal.pem / -key    a *.internal wildcard leaf, valid 825 days
# Every block below loads the leaf via `import internal_tls`, so the served cert
# is a fixed file on disk — it cannot change across reboots or volume wipes.
#
# Install the CA ONCE on every machine/phone that hits the homelab (the CA, not
# the leaf — the CA outlives every leaf re-mint):
#   - Linux: sudo cp hosting/caddy/certs/internal-ca.pem \
#            /usr/local/share/ca-certificates/existential-internal-ca.crt \
#            && sudo update-ca-certificates
#   - macOS: drag internal-ca.pem into Keychain, mark "Always Trust"
#   - iOS / Android: AirDrop / Settings → Security → install certificate
#   - Firefox: about:preferences#privacy → View Certificates → Import
#
# Rotate the leaf (e.g. before it expires): delete hosting/caddy/certs/internal-key.pem
# and re-run ./existential.sh run. The CA is untouched, so devices stay trusted.

{
  auto_https disable_redirects
}

(error_handling) {
  handle_errors {
    root * /var/www/html
    file_server
    rewrite * /error.html
  }
}

# Stable pinned leaf shared by every <slug>.internal block (see header).
(internal_tls) {
  tls /etc/caddy/certs/internal.pem /etc/caddy/certs/internal-key.pem
}

# ── ai ──────────────────────────────────────────────────────────────────────
chatterbox.internal {
  import internal_tls
  import error_handling
  reverse_proxy chatterbox:8000
}

comfyui.internal {
  import internal_tls
  import error_handling
  reverse_proxy comfyui:8188
}

hermes-agent.internal {
  import internal_tls
  import error_handling
  reverse_proxy hermes-agent:8642
}

hermes-agent-dashboard.internal {
  import internal_tls
  import error_handling
  reverse_proxy hermes-agent:9119
}

firecrawl.internal {
  import internal_tls
  import error_handling
  reverse_proxy firecrawl:3002
}

ollama.internal {
  import internal_tls
  import error_handling
  reverse_proxy ollama:11434
}

open-webui.internal {
  import internal_tls
  import error_handling
  reverse_proxy open-webui:8080
}

openviking.internal {
  import internal_tls
  import error_handling
  reverse_proxy openviking:1933
}

mcp-playwright.internal {
  import internal_tls
  import error_handling
  reverse_proxy mcp-playwright:8931
}

whisperx.internal {
  import internal_tls
  import error_handling
  reverse_proxy whisperx:8000
}

# ── services ────────────────────────────────────────────────────────────────

actual-budget.internal {
  import internal_tls
  import error_handling
  reverse_proxy actual-budget:5006
}

appsmith.internal {
  import internal_tls
  import error_handling
  reverse_proxy appsmith:80
}

code-server.internal {
  import internal_tls
  import error_handling
  reverse_proxy code-server:8080
}

dashy.internal {
  import internal_tls
  import error_handling
  reverse_proxy dashy:8080
}

decree-webhook.internal {
  import internal_tls
  import error_handling
  reverse_proxy decree-webhook:{$DECREE_WEBHOOK_PORT}
}

homeassistant.internal {
  import internal_tls
  import error_handling
  reverse_proxy homeassistant:8123
}

immich.internal {
  import internal_tls
  import error_handling
  reverse_proxy immich-server:2283
}

it-tools.internal {
  import internal_tls
  import error_handling
  reverse_proxy it-tools:80
}

lowcoder.internal {
  import internal_tls
  import error_handling
  reverse_proxy lowcoder-frontend:3000
}

mealie.internal {
  import internal_tls
  import error_handling
  reverse_proxy mealie:9000
}

ntfy.internal {
  import internal_tls
  import error_handling
  reverse_proxy ntfy:80
}

nocodb.internal {
  import internal_tls
  import error_handling
  reverse_proxy nocodb:8080
}

vikunja.internal {
  import internal_tls
  import error_handling
  reverse_proxy vikunja:3456
}

# ── hosting ─────────────────────────────────────────────────────────────────
grafana.internal {
  import internal_tls
  import error_handling
  reverse_proxy grafana:3000
}

pihole.internal {
  import internal_tls
  import error_handling
  reverse_proxy pihole:80
}

# Portainer serves HTTPS on 9443 with its own self-signed cert. Caddy talks to
# it over TLS and skips verification — the user-facing cert is still Caddy's.
portainer.internal {
  import internal_tls
  import error_handling
  reverse_proxy https://portainer:9443 {
    transport http {
      tls
      tls_insecure_skip_verify
    }
  }
}

prometheus.internal {
  import internal_tls
  import error_handling
  reverse_proxy prometheus:9090
}

uptime-kuma.internal {
  import internal_tls
  import error_handling
  reverse_proxy uptime-kuma:3001
}

# ── nas ─────────────────────────────────────────────────────────────────────
collabora.internal {
  import internal_tls
  import error_handling
  reverse_proxy collabora:9980
}

# minio web console (port 9001)
minio.internal {
  import internal_tls
  import error_handling
  reverse_proxy minio:9001
}

# minio S3 API (port 9000)
minio-api.internal {
  import internal_tls
  import error_handling
  reverse_proxy minio:9000
}

nextcloud.internal {
  import internal_tls
  import error_handling
  redir /.well-known/carddav /remote.php/dav/ 301
  redir /.well-known/caldav /remote.php/dav/ 301
  reverse_proxy nextcloud:80
}
