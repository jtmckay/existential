# Caddy reverse proxy — `<slug>.<domain>` convention.
#
# Each block fronts one logical endpoint on the LAN. Hostnames use Caddy's native
# env form {$CADDY_DOMAIN}, so the domain is read from the container env at startup —
# the live Caddyfile never bakes it in. CADDY_DOMAIN is set in this service's
# .env.exist (defaults to EXIST_DOMAIN) and passed in via docker-compose. To change
# the domain, edit CADDY_DOMAIN and restart caddy — no re-render.
#
# This file is the SINGLE source of truth for which `<slug>.<domain>` hostnames
# exist — piHole resolves the whole domain with one wildcard record, so adding a
# service only touches this file (and Dashy, if you want a link). `validate
# conventions` keys off these blocks.
#
# The service host runs THIS Caddyfile in both single-host and peer mode. In peer
# mode a front-door Caddy (Caddyfile.frontdoor-lan / -public.example) wildcard-forwards every
# `<slug>.<domain>` here.
#
# ── Stable local TLS ( `import internal_tls` ) ─────────────────────────────
# We deliberately do NOT use `tls internal`: Caddy auto-rotates its internal
# leaf certs (~12h) and keeps the CA in the caddy_data volume, so a volume wipe
# — or a device that trusted a rotating leaf instead of the CA — silently breaks
# trust and forces a re-setup (the ntfy mobile app is the usual casualty).
#
# Instead, caddy's exist.initial.sh mints ONE long-lived pair on the host into
# hosting/caddy/certs/ (mounted at /etc/caddy/certs/):
#   - internal-ca.pem        your private CA, valid 10 years   ← install on devices
#   - internal.pem / -key    a *.<domain> wildcard leaf, valid 825 days
# Every block below loads the leaf via `import internal_tls`, so the served cert
# is a fixed file on disk — it cannot change across reboots or volume wipes.
#
# Install the CA ONCE on every machine/phone that hits the homelab (the CA, not
# the leaf — the CA outlives every leaf re-mint):
#   - Linux: sudo cp hosting/caddy/certs/internal-ca.pem \
#            /usr/local/share/ca-certificates/existential-internal-ca.crt \
#            && sudo update-ca-certificates
#   - macOS: drag internal-ca.pem into Keychain, mark "Always Trust"
#   - iOS / Android: AirDrop / Settings → Security → install certificate
#   - Firefox: about:preferences#privacy → View Certificates → Import
#
# Rotate the leaf (e.g. before it expires): delete hosting/caddy/certs/internal-key.pem
# and re-run ./existential.sh run. The CA is untouched, so devices stay trusted.

(error_handling) {
  handle_errors {
    root * /var/www/html
    file_server
    rewrite * /error.html
  }
}

# Stable pinned leaf shared by every <slug>.<domain> block (see header).
(internal_tls) {
  tls /etc/caddy/certs/internal.pem /etc/caddy/certs/internal-key.pem
}

# Authelia forward-auth gate. A protected vhost `import authelia_protect` — the
# request is bounced to the Authelia portal (authelia.<domain>) and only forwarded
# once authenticated; Authelia injects the Remote-* identity headers. OMIT this for
# services with mobile/desktop/API/token clients (they can't follow the redirect):
# ntfy, immich, nextcloud, homeassistant, minio-api, decree-webhook, hermes, etc.
# Requires the authelia service (EXIST_IS_HOSTING_AUTHELIA=true).
(authelia_protect) {
  forward_auth authelia:9091 {
    uri /api/authz/forward-auth
    copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
  }
}

# ── ai ──────────────────────────────────────────────────────────────────────
chatterbox.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy chatterbox:8000
}

comfyui.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy comfyui:8188
}

hermes-agent.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy hermes-agent:8642
}

hermes-agent-dashboard.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy hermes-agent:9119
}

firecrawl.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy firecrawl:3002
}

ollama.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy ollama:11434
}

open-webui.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy open-webui:8080
}

openviking.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy openviking:1933
}

mcp-playwright.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy mcp-playwright:8931
}

whisperx.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy whisperx:8000
}

# ── services ────────────────────────────────────────────────────────────────

actual-budget.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy actual-budget:5006
}

appsmith.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy appsmith:80
}

code-server.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy code-server:8080
}

dashy.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy dashy:8080
}

decree-webhook.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy decree-webhook:{$DECREE_WEBHOOK_PORT}
}

homeassistant.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy homeassistant:8123
}

immich.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy immich-server:2283
}

it-tools.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy it-tools:80
}

lowcoder.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy lowcoder-frontend:3000
}

mealie.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy mealie:9000
}

ntfy.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy ntfy:80
}

nocodb.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy nocodb:8080
}

vikunja.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy vikunja:3456
}

# ── hosting ─────────────────────────────────────────────────────────────────
# Authelia SSO portal — the login page protected vhosts redirect to. Never gate
# this one (it IS the gate).
authelia.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy authelia:9091
}

grafana.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy grafana:3000
}

pihole.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy pihole:80
}

# Portainer serves HTTPS on 9443 with its own self-signed cert. Caddy talks to
# it over TLS and skips verification — the user-facing cert is still Caddy's.
portainer.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy https://portainer:9443 {
    transport http {
      tls
      tls_insecure_skip_verify
    }
  }
}

prometheus.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy prometheus:9090
}

uptime-kuma.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy uptime-kuma:3001
}

# ── nas ─────────────────────────────────────────────────────────────────────
collabora.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy collabora:9980
}

# minio web console (port 9001)
minio.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  import authelia_protect
  reverse_proxy minio:9001
}

# minio S3 API (port 9000)
minio-api.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  reverse_proxy minio:9000
}

nextcloud.{$CADDY_DOMAIN} {
  import internal_tls
  import error_handling
  redir /.well-known/carddav /remote.php/dav/ 301
  redir /.well-known/caldav /remote.php/dav/ 301
  reverse_proxy nextcloud:80
}
