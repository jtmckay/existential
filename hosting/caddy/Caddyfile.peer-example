# ── hosting ─────────────────────────────────────────────────────────────────
grafana.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:43010
}

pihole.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:42480
}

# Portainer serves HTTPS on its host port with its own self-signed cert. Caddy
# talks to it over TLS and skips verification — the user-facing cert is Caddy's.
portainer.internal {
  tls internal
  import error_handling
  reverse_proxy https://{$EXIST_PEER_HOST_IP}:49443 {
    transport http {
      tls
      tls_insecure_skip_verify
    }
  }
}

prometheus.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49090
}

uptime-kuma.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:43001
}

# ── nas ─────────────────────────────────────────────────────────────────────
collabora.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:9980
}

# minio web console (host 49001 → container 9001)
minio.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49001
}

# minio S3 API (host 49000 → container 9000)
minio-api.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49000
}

nextcloud.internal {
  tls internal
  import error_handling
  redir /.well-known/carddav /remote.php/dav/ 301
  redir /.well-known/caldav /remote.php/dav/ 301
  reverse_proxy {$EXIST_PEER_HOST_IP}:48421
}
