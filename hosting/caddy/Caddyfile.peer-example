# Caddy reverse proxy — PEER variant (Caddy on a different host than the services).
#
# Use this when Caddy + piHole run on one machine but the actual services run on
# another. The co-located Caddyfile reverse-proxies to Docker DNS names
# (`service:containerPort`), which only resolves on the service host's `exist`
# network. From a peer, Caddy must reach each service over the LAN instead:
#
#       reverse_proxy {$EXIST_PEER_HOST_IP}:<hostPort>
#
# ── Requirements on the SERVICE host ──────────────────────────────────────
# Each service must publish its port to the host so the peer can reach it. The
# host ports below are the ones from each service's commented-out `ports:`
# block in its docker-compose.exist.yml — deconflicted (mostly the 4xxxx
# scheme) so nothing collides on a single host IP. Uncomment that block on the
# service host to publish the port, e.g. ntfy:
#
#       ports:
#         - "44680:80"
#
# If you publish a service on a different host port, change it here to match.
#
# ── Setup ─────────────────────────────────────────────────────────────────
#   - `{$EXIST_PEER_HOST_IP}` is Caddy's ENV-VAR substitution, expanded from the
#     caddy *container's* environment at config load — NOT from any .env file
#     (Caddy doesn't read .env). To populate it:
#       1. Set EXIST_PEER_HOST_IP in .env.shared to the LAN IP of the service host.
#       2. caddy's docker-compose.exist.yml passes it into the container via
#          `environment: - EXIST_PEER_HOST_IP=${EXIST_PEER_HOST_IP}` (Docker
#          Compose interpolates that from the generated master .env).
#       3. Swap this file in as the live Caddyfile and restart caddy.
#   - In piHole's FTLCONF_dns_hosts, point each `<slug>.internal` record at the
#     IP of THIS machine (the one running Caddy) — Caddy then proxies onward.
#   - `tls internal` is unchanged: Caddy still terminates TLS with its own CA,
#     so the same root-cert trust steps apply (see Caddyfile.exist.Caddyfile).

{
  auto_https disable_redirects
}

(error_handling) {
  handle_errors {
    root * /var/www/html
    file_server
    rewrite * /error.html
  }
}

# ── ai ──────────────────────────────────────────────────────────────────────
chatterbox.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:48004
}

comfyui.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:8188
}

hermes-agent.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:48642
}

hermes-dashboard.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49119
}

hermes-workspace.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49300
}

lightrag.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:49621
}

ollama.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:11434
}

open-webui.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:11488
}

mcp-playwright.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:8931
}

whisperx.internal {
  tls internal
  import error_handling
  reverse_proxy {$EXIST_PEER_HOST_IP}:48000
}

# ── services ────────────────────────────────────────────────────────────────
