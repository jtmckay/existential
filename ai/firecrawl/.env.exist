# API key for all Firecrawl requests (USE_DB_AUTHENTICATION=false — this is the only accepted key)
FIRECRAWL_API_KEY=EXIST_32_CHAR_HEX_KEY

# Auth key for the Bull queue monitor at /api/bull-admin
FIRECRAWL_BULL_AUTH_KEY=EXIST_32_CHAR_HEX_KEY

# Postgres credentials shared between firecrawl-api and firecrawl-postgres
FIRECRAWL_POSTGRES_USER=EXIST_USERNAME
FIRECRAWL_POSTGRES_PASSWORD=EXIST_PASSWORD
