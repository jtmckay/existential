# OpenViking — root API key (used by MCP clients, REST API, and exist.mcp.sh)
OPENVIKING_API_KEY=EXIST_32_CHAR_HEX_KEY

# Embedding model served by Ollama — must be pulled before starting openviking.
# The stack default (pulled by `./existential.sh run ollama pull-models`) is bge-m3.
# Other choices: nomic-embed-text (768-dim), mxbai-embed-large (1024-dim)
OPENVIKING_EMBEDDING_MODEL=bge-m3

# Embedding dimension — must match the model above (bge-m3 → 1024).
OPENVIKING_EMBEDDING_DIM=1024
