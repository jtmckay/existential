# OpenViking — root API key (used by MCP clients, REST API, and exist.mcp.sh)
OPENVIKING_API_KEY=EXIST_32_CHAR_HEX_KEY

# Embedding model served by Ollama — must be pulled before starting openviking.
# Pull command: docker exec ollama ollama pull <model>
# Common choices: nomic-embed-text (768), mxbai-embed-large (1024), bge-m3 (1024)
OPENVIKING_EMBEDDING_MODEL=EXIST_CLI

# Embedding dimension — must match the model chosen above.
# nomic-embed-text → 768 | mxbai-embed-large → 1024 | bge-m3 → 1024
OPENVIKING_EMBEDDING_DIM=EXIST_CLI
