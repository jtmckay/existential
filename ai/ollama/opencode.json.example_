{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest", "--headless"],
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5:4B": {
          "_launch": true,
          "name": "qwen3.5:4B"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.1.31:11434/v1"
      }
    },
    "ollama-local": {
      "models": {
        "qwen3.5:9B": {
          "_launch": true,
          "name": "qwen3.5:9B",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "extraBody": {
              "think": "high"
            }
          }
        }
      },
      "name": "Ollama-Local",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
