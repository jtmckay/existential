{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
      "*": "ask"
    }
  },
  "mcp": {
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "gemma4:e2b": {
          "_launch": true,
          "name": "gemma4:e2b",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "extraBody": {
              "options": {
                "num_ctx": 128000
              }
            }
          }
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://192.168.1.31:11434/v1"
      }
    },
    "ollama-local": {
      "models": {
        "gpt-oss:20b-32k": {
          "_launch": true,
          "name": "gpt-oss:20b-32k",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "extraBody": {
              "think": "high",
              "options": {
                "num_ctx": 32000
              }
            }
          }
        },
        "gemma4:e2b": {
          "_launch": true,
          "name": "gemma4:e2b",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "extraBody": {
              "think": "high",
              "options": {
                "num_ctx": 128000
              }
            }
          }
        },
        "gemma4:26b": {
          "_launch": true,
          "name": "gemma4:26b",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "options": {
            "extraBody": {
              "think": "high",
              "options": {
                "num_ctx": 256000
              }
            }
          }
        }
      },
      "name": "Ollama-Local",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  }
}
