# OpenWebUI — Environment Variables

# Hermes gateway API key — matches EXIST_HERMES_API_KEY in .env.exist
OPEN_WEBUI_HERMES_API_KEY=EXIST_HERMES_API_KEY

# LightRAG API key — matches EXIST_LIGHTRAG_API_KEY; used for the second
# OpenAI-compatible connection so LightRAG models appear in the model picker.
OPEN_WEBUI_LIGHTRAG_API_KEY=EXIST_LIGHTRAG_API_KEY

# Admin account created on first boot
OPEN_WEBUI_ADMIN_NAME=EXIST_USERNAME
OPEN_WEBUI_ADMIN_EMAIL=EXIST_EMAIL
OPEN_WEBUI_ADMIN_PASSWORD=EXIST_PASSWORD

# JWT signing secret — keep separate from other keys
OPEN_WEBUI_SECRET_KEY=EXIST_32_CHAR_HEX_KEY
