# convention-exempt: upstream-env
# This file is mounted directly into the container at /app/.env (see
# docker-compose.yml.example). Keys must match the upstream LightRAG names
# exactly — no LIGHTRAG_ prefix.

# LightRAG API key — required for every REST and MCP request.
# Value flows from EXIST_LIGHTRAG_API_KEY in .env.exist; hermes-agent
# uses the same value when calling the MCP endpoint, so the two stay in sync
# automatically.
LIGHTRAG_API_KEY=EXIST_LIGHTRAG_API_KEY

# LLM — direct to Ollama over the exist Docker network. Earlier versions
# routed entity extraction through hermes-agent's gateway so the model would
# track whatever hermes was set to; in practice that added a hop and meant
# changing hermes's chat model would silently change extraction behavior too.
# Pinning LightRAG to its own Ollama model keeps extraction independent and
# a step closer to the embedding layer.
#
# Pick a model that's already pulled in ollama — `docker exec ollama ollama list`.
LLM_BINDING=openai
LLM_MODEL=gemma3:27b
LLM_BINDING_HOST=http://ollama:11434/v1
LLM_BINDING_API_KEY=ollama

# Embedding — same ollama, same Docker DNS path.
# Do NOT change the embedding model after first ingestion; doing so requires
# wiping rag_storage and re-ingesting the whole vault.
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768
EMBEDDING_BINDING_HOST=http://ollama:11434

PORT=9621
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
OLLAMA_LLM_NUM_PREDICT=9000
