# convention-exempt: upstream-env
# This file is mounted directly into the container at /app/.env (see
# docker-compose.yml.example). Keys must match the upstream LightRAG names
# exactly — no LIGHTRAG_ prefix.

# LightRAG API key — required for every REST and MCP request.
# Value flows from EXIST_LIGHTRAG_API_KEY in .env.exist; hermes-agent
# uses the same value when calling the MCP endpoint, so the two stay in sync
# automatically.
LIGHTRAG_API_KEY=EXIST_LIGHTRAG_API_KEY

# Host path rclone syncs notes into; mounted read-only as /inputs in the
# lightrag container and writable as /notes in lightrag-decree for sync.
LIGHTRAG_NOTES_PATH=EXIST_CLI

# LLM roles — LightRAG supports per-role model overrides.
# EXTRACT (entity/relationship extraction during ingestion) uses the global
# LLM_MODEL. A smaller, instruction-following model is better here: faster,
# cheaper, and more reliable at structured JSON output than large reasoners.
#
# QUERY (answering questions from the graph) uses QUERY_LLM_MODEL, where a
# stronger model improves synthesis quality.
#
# Both point at the same Ollama instance over the exist Docker network.
# Models must be pulled first — see ai/ollama/exist.initial.sh.
LLM_BINDING=openai
LLM_MODEL=qwen2.5:7b
LLM_BINDING_HOST=http://ollama:11434/v1
LLM_BINDING_API_KEY=ollama

QUERY_LLM_MODEL=gemma4:26b
QUERY_LLM_BINDING=openai
QUERY_LLM_BINDING_HOST=http://ollama:11434/v1
QUERY_LLM_BINDING_API_KEY=ollama

# Embedding — same ollama, same Docker DNS path.
# Do NOT change the embedding model after first ingestion without wiping rag_storage.
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_BINDING_HOST=http://ollama:11434

# Document chunking — paragraph-aware splitting respects the structure of
# Obsidian markdown (headers, bullets, linked notes) better than fixed-token.
LIGHTRAG_PARSER=P

# Write log to the writable rag_storage volume (container runs as uid 1000
# and can't write to /app/ directly; default /app/lightrag.log would crash).
LOG_FILE=/app/rag_storage/lightrag.log

PORT=9621
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
OLLAMA_LLM_NUM_PREDICT=9000
