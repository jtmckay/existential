# OpenWebUI — Environment Variables

# Hermes gateway API key — matches HERMES_API_KEY in .env.exist
HERMES_API_KEY=EXIST_DEFAULT_HERMES_API_KEY

# Admin account created on first boot
WEBUI_ADMIN_NAME=EXIST_DEFAULT_USERNAME
WEBUI_ADMIN_EMAIL=EXIST_DEFAULT_EMAIL
WEBUI_ADMIN_PASSWORD=EXIST_DEFAULT_PASSWORD

# JWT signing secret — keep separate from other keys
WEBUI_SECRET_KEY=EXIST_32_CHAR_HEX_KEY
