{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
      "*": "ask"
    }
  },
  "mcp": {
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "type": "local"
    }
  },
  "provider": {
    "vllm-local": {
      "name": "vllm-Local",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:48030/v1"
      },
      "models": {
        "gemma4:e4b-64k": {
          "id": "gemma-4",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "cost": {
            "input": 1,
            "output": 5
          },
          "options": {
            "extraBody": {
              "think": "high"
            }
          }
        }
      }
    }
  }
}
