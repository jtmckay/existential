{
  "name": "existential",
  "build": {
    "context": "../automations",
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/repo,type=bind,consistency=cached",
  "workspaceFolder": "/repo",
  // Symlink the pre-installed node_modules into the workspace so the VS Code
  // TypeScript language server resolves @types/* and package types normally.
  "postCreateCommand": "ln -sf /opt/decree/node_modules /repo/node_modules",
  "customizations": {
    "vscode": {
      "settings": {
        // Use the TypeScript bundled with the project rather than VS Code's built-in.
        "js/ts.tsdk.path": "/opt/decree/node_modules/typescript/lib"
      }
    }
  }
}
