# TrueNAS NFS
TRUENAS_SERVER_ADDRESS=EXIST_DEFAULT_TRUENAS_SERVER_ADDRESS
TRUENAS_PATH=/mnt/something/minio

# Minio
MINIO_ROOT_USER=EXIST_DEFAULT_USERNAME
MINIO_ROOT_PASSWORD=EXIST_DEFAULT_PASSWORD
MINIO_DOMAIN=EXIST_MINIO_DOMAIN
MINIO_SERVER_URL=EXIST_MINIO_SERVER_URL

# Decree webhook — must match DECREE_MINIO_WEBHOOK_AUTH_TOKEN in .env.exist
# and the /minio endpoint secret in services/decree/webhook/config.yml
DECREE_MINIO_WEBHOOK_AUTH_TOKEN=EXIST_DEFAULT_DECREE_MINIO_WEBHOOK_AUTH_TOKEN
