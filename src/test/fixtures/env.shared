# ── Networking ────────────────────────────────────────────────────────────────

EXIST_LOCAL_HOST_IP=127.0.0.1
EXIST_PEER_HOST_IP=127.0.0.1
EXIST_PUBLIC_DOMAIN=
EXIST_DOCKER_NETWORK_SUBNET=10.0.0.0/24

