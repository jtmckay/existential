# Existential Stack Configuration
# Run existential.sh script, or copy this file to .env.exist and fill in your values

#==================================================#
#               Global Configuration               #
#==================================================#

# Service Enablement Configuration
# Set to 'true' to enable a service, 'false' to disable
# Each service corresponds to a subdirectory with docker-compose.yml

# AI Services
EXIST_ENABLE_AI_CHATTERBOX=false
EXIST_ENABLE_AI_HERMES=true
EXIST_ENABLE_AI_LIBRECHAT=false
EXIST_ENABLE_AI_LIGHTRAG=false
EXIST_ENABLE_AI_MCP=true
EXIST_ENABLE_AI_OLLAMA=true
EXIST_ENABLE_AI_OPEN_WEBUI=true
EXIST_ENABLE_AI_WHISPER=false

# Automation Services
EXIST_ENABLE_AUTOMATIONS_PLAYWRIGHT=false

# Hosting Services
EXIST_ENABLE_HOSTING_CADDY=true
EXIST_ENABLE_HOSTING_GRAFANA=true
EXIST_ENABLE_HOSTING_LOKI=true
EXIST_ENABLE_HOSTING_PIHOLE=true
EXIST_ENABLE_HOSTING_PORTAINER=true
EXIST_ENABLE_HOSTING_PROMETHEUS=true
EXIST_ENABLE_HOSTING_UPTIME_KUMA=false

# NAS Services
EXIST_ENABLE_NAS_COLLABORA=false
EXIST_ENABLE_NAS_MINIO=false
EXIST_ENABLE_NAS_NEXTCLOUD=false
EXIST_ENABLE_NAS_REDIS=false

# Application Services
EXIST_ENABLE_SERVICES_ACTUAL_BUDGET=false
EXIST_ENABLE_SERVICES_APPSMITH=false
EXIST_ENABLE_SERVICES_DASHY=true
EXIST_ENABLE_SERVICES_DECREE=true
EXIST_ENABLE_SERVICES_IMMICH=false # Recommended to run this directly from the immich directory (not here)
EXIST_ENABLE_SERVICES_IT_TOOLS=false
EXIST_ENABLE_SERVICES_LOWCODER=false
EXIST_ENABLE_SERVICES_MEALIE=false
EXIST_ENABLE_SERVICES_NOCODB=false
EXIST_ENABLE_SERVICES_NTFY=true
EXIST_ENABLE_SERVICES_VIKUNJA=false

# Set to true if the 'exist' Docker network is created externally (e.g. via docker network create)
# Set to false to have it created and managed by Docker Compose
EXIST_NETWORK_EXTERNAL=false

EXIST_DEFAULT_EMAIL=EXIST_CLI

EXIST_DEFAULT_USERNAME=EXIST_CLI
EXIST_DEFAULT_PASSWORD=EXIST_24_CHAR_PASSWORD

# LAN IP of the machine running THIS clone of the stack. piHole records for every
# enabled service point here so other devices on the LAN resolve `<slug>.internal` →
# this machine → Caddy → the right container.
EXIST_DEFAULT_LOCAL_HOST_IP=EXIST_CLI

# LAN IP of the machine running services NOT enabled on this host. piHole points
# `<slug>.internal` for any service whose EXIST_ENABLE_* is false at this machine.
# Optional — blank defaults to LOCAL_HOST_IP, meaning "disabled = not running anywhere."
# DEFAULT_FROM: EXIST_DEFAULT_LOCAL_HOST_IP
EXIST_DEFAULT_PEER_HOST_IP=EXIST_CLI

# Hermes gateway API key — shared by hermes-agent, hermes-workspace, and open-webui
EXIST_DEFAULT_HERMES_API_KEY=EXIST_32_CHAR_HEX_KEY

# LightRAG API key — shared by lightrag container and hermes-agent MCP config
EXIST_DEFAULT_LIGHTRAG_API_KEY=EXIST_32_CHAR_HEX_KEY

# NTFY (shared across services)
# Internal container-to-container URL — uses Docker's service DNS on the
# `exist` network. Browser-facing access goes through https://ntfy.internal
# (Caddy + piHole). Run ./existential.sh setup ntfy after first boot to set
# a real publish URL if you're using a hosted ntfy instead.
EXIST_DEFAULT_NTFY_URL=http://ntfy:80
EXIST_DEFAULT_NTFY_TOKEN=EXIST_32_CHAR_HEX_KEY

# Docker network subnet (must match your docker network create command)
EXIST_DEFAULT_DOCKER_NETWORK_SUBNET=10.0.0.0/24

#==================================================#
#                 NAS Configuration                #
#==================================================#

# TrueNAS NFS Settings (required for persistent storage)
EXIST_DEFAULT_TRUENAS_SERVER_ADDRESS=EXIST_CLI
EXIST_DEFAULT_TRUENAS_CONTAINER_PATH=EXIST_CLI

# EG: minio-api.internal
EXIST_MINIO_DOMAIN=EXIST_CLI
# EG: https://minio-api.internal
EXIST_MINIO_SERVER_URL=EXIST_CLI

# Bearer token minIO uses when posting to the decree /minio webhook endpoint
DECREE_MINIO_WEBHOOK_AUTH_TOKEN=EXIST_32_CHAR_HEX_KEY

# EG: https://nextcloud.internal
EXIST_NEXTCLOUD_DOMAIN=EXIST_CLI

EXIST_DEFAULT_REDIS_PASSWORD=EXIST_24_CHAR_PASSWORD
